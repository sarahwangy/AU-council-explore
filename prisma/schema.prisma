generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Council {
  id               String        @id
  name             String
  region           String
  state            String        @default("VIC")
  website          String?
  libraryUrl       String?
  libraryPlatform  String?
  population       Int?
  areaSqKm         Float?
  hardRubbishUrl   String?
  kindergartenUrl  String?
  libraryCardUrl   String?
  stats            CouncilStats?
  libraries        Library[]
  events           Event[]
  createdAt        DateTime      @default(now())
}

model CouncilStats {
  id            String   @id @default(cuid())
  councilId     String   @unique
  council       Council  @relation(fields: [councilId], references: [id])
  // Gender (from G01)
  malePercent   Float?
  femalePercent Float?
  medianAge     Int?
  // Age groups as % of total population (from G04)
  agePct0to4    Float?   // Preschool / childcare age
  agePct5to14   Float?   // Primary school age
  agePct15to19  Float?   // Secondary school age
  agePct20to39  Float?   // Young adults
  agePct40to64  Float?   // Middle age
  agePct65plus  Float?   // Seniors
  // Demographics (from G09 + G08)
  overseasBornPct        Float?   // % born overseas
  medianHouseholdIncome  Int?     // weekly median household income (AUD)
  topLanguagesJson       String?  // JSON: [{ language: "Mandarin", pct: 12.3 }, ...]
  dataYear      Int      @default(2021)
  updatedAt     DateTime @updatedAt
}

model Library {
  id        String   @id @default(cuid())
  councilId String
  council   Council  @relation(fields: [councilId], references: [id])
  name      String
  url       String?
  address   String?
  suburb    String?
  phone     String?
  lat       Float?
  lng       Float?
  hoursJson String?  // JSON: { mon:"9:00-18:00", tue:..., sun:null }
  events    Event[]
}

model Event {
  id          String    @id @default(cuid())
  councilId   String
  council     Council   @relation(fields: [councilId], references: [id])
  libraryId   String?
  library     Library?  @relation(fields: [libraryId], references: [id])
  title           String
  description     String?
  category        String?
  ageGroup        String?   // "kids-0-5" | "school-age" | "adult" | "senior" | "all-ages"
  isFree          Boolean   @default(true)
  requiresBooking Boolean   @default(false)
  startAt         DateTime
  endAt           DateTime?
  venue           String?
  bookingUrl      String?
  source          String
  externalId      String?
  createdAt       DateTime  @default(now())

  @@unique([source, externalId])
  @@index([councilId, startAt])
  @@index([category, startAt])
}

model Subscriber {
  id         String   @id @default(cuid())
  email      String   @unique
  councils   String[] // array of council slugs
  token      String   @unique @default(cuid()) // unsubscribe token
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  lastSentAt DateTime?
}

model ScrapeLog {
  id        String   @id @default(cuid())
  councilId String?
  source    String
  status    String
  count     Int?
  error     String?
  runAt     DateTime @default(now())
}

model AiSearchCache {
  id        String   @id @default(cuid())
  queryKey  String   @unique  // normalized lowercase query
  result    String   // JSON stringified SearchResult
  createdAt DateTime @default(now())
  expiresAt DateTime            // TTL — re-fetch after this date
}
